import { Button, CheckBox, ComboBox, GroupBox, LineEdit, ScrollView, Slider, SpinBox, VerticalBox, HorizontalBox } from "std-widgets.slint";

export struct AppEntry {
    name: string,
    excluded: bool,
}

component TipLabel inherits Rectangle {
    in property <string> label: "";
    in property <string> tip: "";

    width: lbl.preferred-width + 4px;
    height: lbl.preferred-height;

    lbl := Text {
        text: root.label;
        vertical-stretch: 0;
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
    }

    if ta.has-hover: Rectangle {
        x: 0px;
        y: parent.height + 4px;
        width: ttxt.preferred-width + 16px;
        height: ttxt.preferred-height + 12px;
        background: #333333;
        border-radius: 4px;
        z: 100;

        ttxt := Text {
            text: root.tip;
            color: white;
            font-size: 12px;
            x: 8px;
            y: 6px;
            width: 300px;
            wrap: word-wrap;
        }
    }
}

export component SettingsWindow inherits Window {
    title: "AutoDuck 设置";
    icon: @image-url("../icon.png");
    preferred-width: 480px;
    preferred-height: 620px;
    min-height: 400px;

    // Callbacks - Rust code will connect to these
    callback apply-settings();
    callback reset-settings();
    callback add-excluded-app(string);
    callback remove-excluded-app(string);
    callback refresh-apps();
    callback window-closed();

    // Properties that Rust code will set
    in-out property <string> duck-mode: "global";
    in-out property <float> duck-ratio: 0.3;
    in-out property <float> vad-threshold: 0.5;
    in-out property <int> attack-frames: 4;
    in-out property <int> release-frames: 30;
    in-out property <string> attack-ms: "96";
    in-out property <string> release-ms: "480";

    callback attack-ms-changed(string);
    callback release-ms-changed(string);
    in-out property <int> duck-duration-ms: 120;
    in-out property <int> restore-duration-ms: 120;
    in-out property <float> spectral-flatness-threshold: 0.65;
    in-out property <float> noise-floor-multiplier: 2.0;
    in-out property <[AppEntry]> app-list: [];
    in-out property <string> new-app-name: "";
    in-out property <string> status-text: "";

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        ScrollView {
            VerticalBox {
                spacing: 12px;

                // 降音模式
                GroupBox {
                    title: "降音模式";
                    HorizontalBox {
                        ComboBox {
                            model: ["全局降音", "应用排除"];
                            current-value: duck-mode == "global" ? "全局降音" : "应用排除";
                            selected(changed-value) => {
                                if changed-value == "全局降音" {
                                    duck-mode = "global";
                                } else {
                                    duck-mode = "apps";
                                }
                            }
                        }
                    }
                }

                // 音量设置
                GroupBox {
                    title: "音量设置";
                    VerticalBox {
                        spacing: 8px;

                        HorizontalBox {
                            Text { text: "降音比例:"; vertical-stretch: 0; min-width: 100px; }
                            Slider {
                                minimum: 0.0;
                                maximum: 1.0;
                                value: duck-ratio;
                                changed(val) => { duck-ratio = val; }
                            }
                            Text { text: round(duck-ratio * 100) + "%"; min-width: 50px; vertical-stretch: 0; }
                        }

                        HorizontalBox {
                            Text { text: "降音渐变:"; vertical-stretch: 0; min-width: 100px; }
                            Slider {
                                minimum: 50;
                                maximum: 500;
                                value: duck-duration-ms;
                                changed(val) => { duck-duration-ms = round(val); }
                            }
                            Text { text: duck-duration-ms + "ms"; min-width: 50px; vertical-stretch: 0; }
                        }

                        HorizontalBox {
                            Text { text: "恢复渐变:"; vertical-stretch: 0; min-width: 100px; }
                            Slider {
                                minimum: 50;
                                maximum: 500;
                                value: restore-duration-ms;
                                changed(val) => { restore-duration-ms = round(val); }
                            }
                            Text { text: restore-duration-ms + "ms"; min-width: 50px; vertical-stretch: 0; }
                        }
                    }
                }

                // VAD 设置
                GroupBox {
                    title: "语音检测";
                    VerticalBox {
                        spacing: 8px;

                        HorizontalBox {
                            Text { text: "触发阈值:"; vertical-stretch: 0; min-width: 100px; }
                            Slider {
                                minimum: 0.1;
                                maximum: 0.9;
                                value: vad-threshold;
                                changed(val) => { vad-threshold = val; }
                            }
                            Text { text: round(vad-threshold * 100) + "%"; min-width: 50px; vertical-stretch: 0; }
                        }

                        HorizontalBox {
                            Text { text: "反应时长:"; vertical-stretch: 0; min-width: 100px; }
                            LineEdit {
                                text: attack-ms;
                                edited(val) => {
                                    attack-ms = val;
                                    attack-ms-changed(val);
                                }
                            }
                            Text { text: "ms"; vertical-stretch: 0; min-width: 30px; }
                        }

                        HorizontalBox {
                            Text { text: "恢复间隔:"; vertical-stretch: 0; min-width: 100px; }
                            LineEdit {
                                text: release-ms;
                                edited(val) => {
                                    release-ms = val;
                                    release-ms-changed(val);
                                }
                            }
                            Text { text: "ms"; vertical-stretch: 0; min-width: 30px; }
                        }

                        HorizontalBox {
                            TipLabel {
                                label: "噪声过滤※";
                                tip: "频谱平坦度阈值：衡量声音信号的频率分布均匀程度。值越低，越容易将均匀噪声（如风扇声）识别为非语音，从而避免误触发降音。建议保持默认值。";
                                min-width: 100px;
                                vertical-stretch: 0;
                            }
                            Slider {
                                minimum: 0.0;
                                maximum: 1.0;
                                value: spectral-flatness-threshold;
                                changed(val) => { spectral-flatness-threshold = val; }
                            }
                            Text { text: round(spectral-flatness-threshold * 100) + "%"; min-width: 50px; vertical-stretch: 0; }
                        }

                        HorizontalBox {
                            TipLabel {
                                label: "噪声适应※";
                                tip: "噪声底噪倍率：在安静环境下自动测量的背景噪声基础上，乘以此倍率作为有效检测阈值。值越大，需要越大的声音才能触发降音。如果环境噪音大导致频繁误触发，可适当增大此值。";
                                min-width: 100px;
                                vertical-stretch: 0;
                            }
                            Slider {
                                minimum: 1.0;
                                maximum: 5.0;
                                value: noise-floor-multiplier;
                                changed(val) => { noise-floor-multiplier = val; }
                            }
                            Text { text: round(noise-floor-multiplier * 10) / 10; min-width: 50px; vertical-stretch: 0; }
                        }
                    }
                }

                // 应用排除列表
                GroupBox {
                    title: "排除应用";
                    VerticalBox {
                        spacing: 8px;

                        HorizontalBox {
                            LineEdit {
                                placeholder-text: "输入进程名 (如 Music.exe)";
                                text: new-app-name;
                                edited(val) => { new-app-name = val; }
                            }
                            Button {
                                text: "添加";
                                clicked => {
                                    add-excluded-app(new-app-name);
                                    new-app-name = "";
                                }
                            }
                            Button {
                                text: "刷新";
                                clicked => { refresh-apps(); }
                            }
                        }

                        // App list with checkboxes
                        for entry[idx] in app-list: HorizontalBox {
                            CheckBox {
                                text: entry.name;
                                checked: entry.excluded;
                                toggled => {
                                    if self.checked {
                                        add-excluded-app(entry.name);
                                    } else {
                                        remove-excluded-app(entry.name);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        // 底部按钮
        HorizontalBox {
            alignment: end;
            spacing: 8px;

            Text {
                text: status-text;
                vertical-alignment: center;
                color: #666666;
            }

            Button {
                text: "重置默认";
                clicked => { reset-settings(); }
            }
            Button {
                text: "应用";
                primary: true;
                clicked => { apply-settings(); }
            }
        }
    }
}
